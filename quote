name: Update Quote

on:
  schedule:
    - cron: '0 0 * * *' # 每天北京时间早上 8 点自动更新
  workflow_dispatch: # 允许你手动点击运行

# 解决 Node.js 20 警告的设置
env:
  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true

jobs:
  update-quote:
    runs-on: ubuntu-latest
    permissions:
      contents: write # 必须赋予写入权限，机器人才能改你的 README
    steps:
      - name: Checkout
        uses: actions/checkout@v4
      
      - name: Fetch Quote and Update README
        run: |
          # 获取格言并处理可能影响 sed 的特殊字符
          QUOTE=$(curl -s https://v1.hitokoto.cn/?c=i&encode=text)
          echo "获取到的格言: $QUOTE"
          
          # 使用 sed 替换 README 中的占位符
          # 如果你的占位符之间有内容，这段代码会把旧内容刷成新内容
          sed -i "//,//c\\n> $QUOTE\n" README.md
      
      - name: Commit and Push
        run: |
          git config --global user.name "github-actions[bot]"
          git config --global user.email "github-actions[bot]@users.noreply.github.com"
          # 检查是否有改动，防止没有新格言时报错
          if [ -n "$(git status --porcelain)" ]; then
            git add README.md
            git commit -m "🤖 自动更新每日格言"
            git push
          else
            echo "没有内容变化，跳过推送。"
          fi
